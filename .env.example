# OpenWA Gateway
OPENWA_API_URL=http://localhost:2785/api
OPENWA_API_KEY=your-api-key-here
OPENWA_SESSION_ID=sess_default

# Webhook (bot receives webhooks from OpenWA)
WEBHOOK_PORT=2889
WEBHOOK_SECRET=your-webhook-secret-change-me
WEBHOOK_URL=http://swapbot:2889/webhook

# Boltz Exchange
BOLTZ_API_URL=https://api.boltz.exchange

# ChangeNOW (for USDT/USDC swaps across all networks)
# Get API key at https://changenow.io/
CHANGENOW_API_KEY=

# Admin
ADMIN_PHONE=12345678901  # Phone number without +, used for admin commands

# Commission (1.5 - 2.5)
COMMISSION_RATE=2.5

# Database
DATABASE_PATH=./data/swapbot.db
