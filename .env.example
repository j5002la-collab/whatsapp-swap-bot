# ══════════════════════════════════════════
# CryptoSwapBot v2 — Configuración
# ══════════════════════════════════════════

# ── OpenWA Gateway ──
# 🔴 En Umbrel con network_mode=host → usa localhost:
OPENWA_API_URL=http://localhost:2785/api
#
# 🔴 En Umbrel con OpenWA en otro contenedor → usa host IP:
#   Primero averigua la IP del host Umbrel:
#     docker inspect -f '{{range.NetworkSettings.Networks}}{{.IPAddress}}{{end}}' openwa-api
#   O usa la IP de Umbrel en tu red local:
#     OPENWA_API_URL=http://192.168.1.XX:2785/api
#
# 🔴 Con docker-compose compartido:
#   OPENWA_API_URL=http://openwa-api:2785/api

OPENWA_API_KEY=owa_k1_689dfcb7ef10a1b0b6803c22a4d5c24f5d6ccda2ea5332bfe3c6b70f28e911d7
OPENWA_SESSION_ID=sess_default

# ── Webhook (bot recibe webhooks de OpenWA) ──
WEBHOOK_PORT=2889
WEBHOOK_SECRET=!!!CAMBIA-ESTO-POR-ALGO-SEGURO!!!
# OpenWA necesita poder llegar a esta URL para enviar webhooks.
# En Umbrel con network_mode=host, OpenWA ve el host también:
WEBHOOK_URL=http://localhost:2889/webhook

# ── ChangeNOW API Key (OBLIGATORIO) ──
# Consíguela en https://changenow.io/ → Sign Up → API Keys
CHANGENOW_API_KEY=tu-api-key-de-changenow

# ── Admin ──
# Número de WhatsApp del admin SIN el + (ej: 5491112345678)
ADMIN_PHONE=5491112345678

# ── Database ──
DATABASE_PATH=./data/swapbot.db

# ── Logging ──
LOG_LEVEL=INFO
